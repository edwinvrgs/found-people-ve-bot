generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FoundPerson {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String   @map("full_name")
  relevantInfo String?  @map("relevant_info")
  documentId   String?  @map("document_id")
  sourceUrl    String   @map("source_url")
  sourceHash   String   @unique @map("source_hash")
  raw          Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([documentId], map: "idx_found_people_document_id")
  @@index([updatedAt(sort: Desc)], map: "idx_found_people_updated_at")
  @@map("found_people")
}

model FoundPeopleMergeAudit {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  canonicalId      String   @map("canonical_id") @db.Uuid
  duplicateId      String   @map("duplicate_id") @db.Uuid
  reason           String
  confidence       String
  beforeCanonical  Json     @map("before_canonical")
  beforeDuplicate  Json     @map("before_duplicate")
  plannedCanonical Json     @map("planned_canonical")
  appliedBy        String   @map("applied_by")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([canonicalId], map: "idx_found_people_merge_audit_canonical_id")
  @@index([duplicateId], map: "idx_found_people_merge_audit_duplicate_id")
  @@map("found_people_merge_audit")
}

model BotMetric {
  name      String   @id
  value     BigInt   @default(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("bot_metrics")
}

model TelegramChat {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId            BigInt    @unique @map("chat_id")
  username          String?
  chatType          String    @default("unknown") @map("chat_type")
  broadcastOptOut   Boolean   @default(false) @map("broadcast_opt_out")
  blockedAt         DateTime? @map("blocked_at") @db.Timestamptz(6)
  firstSeenAt       DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt        DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([lastSeenAt(sort: Desc)], map: "idx_telegram_chats_last_seen_at")
  @@index([username], map: "idx_telegram_chats_username")
  @@map("telegram_chats")
}
